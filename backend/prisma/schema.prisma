generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  batchId   Int?
  facultyId Int?
  batch     Batch?   @relation(fields: [batchId], references: [id])
  faculty   Faculty? @relation(fields: [facultyId], references: [id])
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  code      String    @unique
  createdAt DateTime  @default(now())
  batches   Batch[]
  courses   Course[]
  faculty   Faculty[]
}

model Course {
  id           Int              @id @default(autoincrement())
  name         String
  code         String           @unique
  type         CourseType
  departmentId Int
  createdAt    DateTime         @default(now())
  facultyId    Int?
  weeklyHours  Int              @default(4)
  department   Department       @relation(fields: [departmentId], references: [id])
  faculty      Faculty?         @relation(fields: [facultyId], references: [id])
  timetable    TimetableEntry[]
}

model Faculty {
  id             Int                   @id @default(autoincrement())
  name           String
  email          String                @unique
  maxLoad        Int
  departmentId   Int
  createdAt      DateTime              @default(now())
  maxWeeklyLoad  Int                   @default(16)
  courses        Course[]
  department     Department            @relation(fields: [departmentId], references: [id])
  availabilities FacultyAvailability[]
  timetable      TimetableEntry[]
  user           User[]
}

model Batch {
  id           Int              @id @default(autoincrement())
  semester     Int
  size         Int
  departmentId Int
  createdAt    DateTime         @default(now())
  department   Department       @relation(fields: [departmentId], references: [id])
  timetable    TimetableEntry[]
  users        User[]
}

model Room {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  type      RoomType
  capacity  Int
  createdAt DateTime         @default(now())
  isLab     Boolean          @default(false)
  timetable TimetableEntry[]
}

model TimeSlot {
  id                    Int                   @id @default(autoincrement())
  day                   Day
  startTime             String
  endTime               String
  facultyAvailabilities FacultyAvailability[]
  timetable             TimetableEntry[]
}

model TimetableEntry {
  id         Int      @id @default(autoincrement())
  batchId    Int
  courseId   Int
  facultyId  Int
  roomId     Int
  timeSlotId Int
  createdAt  DateTime @default(now())
  batch      Batch    @relation(fields: [batchId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])
  faculty    Faculty  @relation(fields: [facultyId], references: [id])
  room       Room     @relation(fields: [roomId], references: [id])
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id])

  @@unique([batchId, timeSlotId])
  @@unique([facultyId, timeSlotId])
  @@unique([roomId, timeSlotId])
}

model FacultyAvailability {
  id         Int      @id @default(autoincrement())
  facultyId  Int
  timeSlotId Int
  faculty    Faculty  @relation(fields: [facultyId], references: [id])
  timeSlot   TimeSlot @relation(fields: [timeSlotId], references: [id])

  @@unique([facultyId, timeSlotId])
}

enum Role {
  ADMIN
  STUDENT
  FACULTY
}

enum CourseType {
  THEORY
  LAB
}

enum RoomType {
  CLASSROOM
  LAB
}

enum Day {
  MON
  TUE
  WED
  THU
  FRI
}
